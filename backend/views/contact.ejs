<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us</title>

    <link rel="stylesheet" href="contact.css">
    <link rel="icon" href="/images/logo.jpg">
</head>

<body>

    <!-- NAVBAR -->

    <header>

        <div class="navbar">

            <div class="logo">
                <img src="/images/logo.jpg" alt="PulmoAi"> <span>PulmoAi</span>
            </div>

            <ul>
                <li><a href="/home">Home</a></li>
                <li><a href="add-patient.ejs">New Patient</a></li>
                <li><a href="patientlist.tml">Patient List</a></li>
                <li><a href="about.html">About</a></li>
                <li><a href="settings.html">Setting</a></li>
            </ul>

            <button class="profile-btn"><a href="doctor.html">My Pofile</a></button>

        </div>

    </header>


    <!-- CONTACT HEADER -->

    <section class="contact-header">

        <h1>Contact Us</h1>

        <p>If you have any questions or need support regarding the LungAI Diagnosis System, feel free to contact us.</p>

    </section>


    <!-- CONTACT INFO -->

    <section class="contact-info">

        <div class="card">
            <h3>Email</h3>
            <p>support@lungai.com</p>
        </div>

        <div class="card">
            <h3>Phone</h3>
            <p>+91 XXXXX XXXXX</p>
        </div>

        <div class="card">
            <h3>Address</h3>
            <p>Malwa Institute of Technology, Indore<br>Madhay Pradesh, India</p>
        </div>

    </section>


    <!-- CONTACT FORM -->

    <section class="contact-form">

        <h2>Contact Form</h2>

        <form id="contactForm" onsubmit="return validateContactForm()">

            <div class="form-row">

                <div class="input-box">
                    <label>Name</label>
                    <input id="name" type="text" placeholder="Your Name">
                </div>

                <div class="input-box">
                    <label>Email</label>
                    <input id="email" type="email" placeholder="Your Email">
                </div>

            </div>

            <label>Message</label>
            <textarea id="message" rows="5" placeholder="Your Message"></textarea>

            <p id="charCount">0 characters</p>

            <button type="submit" class="send-btn">Send Message</button>

        </form>

    </section>


    <!-- SUCCESS POPUP -->

    <div id="contactPopup" class="popup">

        <div class="popup-box">

            <h3>Message Sent Successfully</h3>

            <p>We will contact you soon.</p>

            <button onclick="closePopup()">OK</button>

        </div>

    </div>


    <!-- FOOTER -->

    <footer>

        <div class="footer">

            <div class="left">

                <p>© Copyright LungAI Diagnosis System</p>

                <p class="desc">
                    This system helps doctors detect lung diseases earlier and improve diagnosis speed.
                </p>

            </div>

            <div class="right">

                <h4>Quick Links</h4>
                <p><a href="index.html">Home</a> | <a href="about.html">About</a> </p>

            </div>

        </div>

    </footer>


    <!-- JAVASCRIPT -->

    <script src="contact.js"></script>

</body>

</html>
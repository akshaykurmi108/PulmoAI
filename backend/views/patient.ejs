<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Patient Details</title>
    <link rel="stylesheet" href="patient.css">
</head>

<body>

    <div id="notification"></div>

    <header>
        <div class="navbar">
            <div class="logo">
                <img src="logo.jpg" alt="PulmoAi"> <span>PulmoAi</span>
            </div>

            <ul>
                <li><a href="index.html">Home</a></li>
                <li><a href="add-patient.html">New Patient</a></li>
                <li><a href="patientlist.html">Patient List</a></li>
                <li><a href="about.html">About</a></li>
                <li><a href="contact.html">Contact</a></li>
                <li><a href="settings.html">Setting</a></li>
            </ul>

            <button class="login-btn"><a href="doctor.html">My Profile</a></button>
        </div>
    </header>


    <!-- PATIENT HEADER -->

    <section class="patient-header">

        <img src="patient.jpg" alt="Patient image" class="patient-img">

        <div class="patient-info">
            <h2>Patient Name: Rahul Shelby</h2>
            <p>Age: 34 | Gender: Male | Patient ID: P1023</p>
            <p>Doctor: Dr. Raj Sharma</p>
            <p>Hospital: City Hospital</p>
        </div>

        <div class="patient-actions">

            <button onclick="enableEdit()">Edit</button>
            <button onclick="saveDetails()">Save</button>
            <button onclick="deletePatient()">Delete</button>

        </div>

    </section>


    <!-- QUICK STATS -->

    <section class="stats">

        <div class="card">
            <h3>Total Scans</h3>
            <h2>5</h2>
        </div>

        <div class="card">
            <h3>AI Reports</h3>
            <h2>5</h2>
        </div>

        <div class="card">
            <h3>Last Scan Date</h3>
            <h2>12 May</h2>
        </div>

        <div class="card">
            <h3>Disease Risk</h3>
            <h2>High</h2>
        </div>

    </section>


    <!-- PROFILE DETAILS -->

    <section class="profile-details">

        <div class="box">

            <h3>Personal Details</h3>

            <label>Full Name</label>
            <input class="editable" value="Rahul Shelby" readonly>

            <label>Age</label>
            <input class="editable" value="45" readonly>

            <label>Gender</label>
            <input class="editable" value="Male" readonly>

            <label>Phone</label>
            <input class="editable" value="0123-455-9771" readonly>

        </div>

        <div class="box">

            <h3>Health Details</h3>

            <label>Weight</label>
            <input class="editable" value="45kg" readonly>

            <label>Height</label>
            <input class="editable" value="172cm" readonly>

            <label>Smoking History</label>
            <input class="editable" value="10 years" readonly>

            <label>Allergies</label>
            <input class="editable" value="Penicillin" readonly>

        </div>

    </section>


    <!-- SCAN HISTORY -->

    <section class="scan-history">

        <h2>Scan History</h2>

        <table>

            <tr>
                <th>Date</th>
                <th>Scan Type</th>
                <th>Result</th>
                <th>Status</th>
                <th>Action</th>
            </tr>

            <tr>
                <td>12 May</td>
                <td>CT Scan</td>
                <td>Normal</td>
                <td class="complete">Completed</td>
                <td><button onclick="downloadReport()">Download Report</button></td>
            </tr>

            <tr>
                <td>10 May</td>
                <td>X-Ray</td>
                <td>Pneumonia</td>
                <td class="complete">Completed</td>
                <td><button onclick="downloadReport()">Download Report</button></td>
            </tr>

            <tr>
                <td>05 May</td>
                <td>CT Scan</td>
                <td>Processing</td>
                <td class="pending">Pending</td>
                <td><button onclick="checkReport()">Analyze Report</button></td>
            </tr>

        </table>

    </section>


    <!-- REPORT STATUS -->

    <section class="report-status">

        <h3>Report Status</h3>

        <p id="reportStatus">Pending Analysis</p>

        <button onclick="checkReport()">Analyze Report</button>

    </section>


    <!-- AI RESULT -->

    <section class="ai-result">

        <img src="scan.png" alt="Lungs Image">

        <div class="result-text">

            <h3>AI Findings</h3>

            <p>Possible Lung Nodule Detected</p>
            <p>Probability: 92%</p>
            <p>Risk Level: High</p>
            <p>Suggested Diagnosis: Possible Early Lung Cancer</p>

        </div>

    </section>


    <!-- DOWNLOAD REPORTS -->

    <section class="reports">

        <h2>Downloadable Reports</h2>

        <table>

            <tr>
                <th>Report Name</th>
                <th>Date</th>
                <th>Action</th>
            </tr>

            <tr>
                <td>AI Report</td>
                <td>12 May</td>
                <td><button onclick="downloadReport()">Download</button></td>
            </tr>

            <tr>
                <td>Scan Report</td>
                <td>10 May</td>
                <td><button onclick="downloadReport()">Download</button></td>
            </tr>

        </table>

    </section>

    <script src="patient.js"></script>

</body>

</html>
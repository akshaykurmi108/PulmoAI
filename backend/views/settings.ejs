<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Settings</title>
    <link rel="stylesheet" href="settings.css">
</head>

<body>

    <div id="notification"></div>


    <header>

        <div class="navbar">

            <div class="logo">
                <img src="/images/logo.jpg" alt="PulmoAi"> <span>PulmoAi</span>
                <h2 style="margin-left:200px;">Settings</h2>
            </div>

            <button class="login-btn"><a href="/doctorProfile">My Profile</a></button>

        </div>

    </header>


    <div class="container">


        <!-- LEFT SIDEBAR -->

        <div class="sidebar">

            <div class="menu active">Account Settings</div>
            <div class="menu">Security Settings</div>
            <div class="menu">Notification Settings</div>
            <div class="menu">System Preferences</div>

            <button class="side-btn">Clear History</button>
            <button class="side-btn">Download My Data</button>
            <button class="side-btn">Delete Account</button>

        </div>



        <!-- RIGHT CONTENT -->

        <div class="content">

            <!-- PASSWORD FORM -->

            <div class="card">

                <h2>Security Settings</h2>

                <form id="passwordForm">

                    <label>Current Password</label>
                    <input id="currentPassword" type="password" placeholder="Current Password">

                    <label>New Password</label>
                    <input id="newPassword" type="password" placeholder="New Password">

                    <label>Confirm Password</label>
                    <input id="confirmPassword" type="password" placeholder="Confirm Password">

                    <button type="button" onclick="changePassword()">Update Password</button>

                </form>

            </div>



            <!-- DARK MODE + LOGIN ACTIVITY -->

            <div class="card">

                <h3>Two-Factor Authentication (2FA)</h3>

                <label class="switch">
                    <input type="checkbox">
                    <span class="slider"></span>
                </label>

                <h3>Login Activity</h3>

                <ul class="activity">
                    <li>12 May 2026 – 09:15 AM – India</li>
                    <li>11 May 2026 – 02:30 PM – Indore</li>
                    <li>11 May 2026 – 08:45 AM – Delhi</li>
                </ul>

                <button class="secondary-btn">Logout From All Devices</button>

            </div>



            <!-- NOTIFICATION SETTINGS -->

            <div class="card">

                <h2>Notification Settings</h2>

                <label>
                    <input id="notificationToggle" type="checkbox" onclick="toggleNotifications()"> Enable Notifications
                </label>

                <label><input type="checkbox"> AI Analysis Results Alert</label>
                <label><input type="checkbox"> Patient Report Updates</label>
                <label><input type="checkbox"> System Notifications</label>

            </div>



            <!-- SYSTEM PREFERENCES -->

            <div class="card">

                <h2>System Preferences</h2>

                <label>
                    <input type="checkbox" onclick="toggleDarkMode()"> Dark Mode
                </label>

                <br><br>

                <label>Dashboard Layout</label>
                <select>
                    <option>Standard</option>
                    <option>Compact</option>
                </select>

                <label>Default Scan Type</label>
                <select>
                    <option>X-Ray</option>
                </select>

            </div>



            <!-- SAVE SETTINGS + LOGOUT -->

            <div class="card">

                <button onclick="saveSettings()">Save Settings</button>

                <button onclick="logout()">Logout</button>

            </div>



            <!-- ACTIVITY LOG -->

          

        </div>

    </div>


    <footer>

        <p>© Copyright LungAI Diagnosis System</p>

    </footer>
    <script src="settings.js"></script>

</body>

</html>